# Dripp Tracker — backend environment (copy to .env for local dev; set the
# same keys in the Render dashboard for production). Never commit real values.

# === DATABASE ===
# Production: NEW Neon project 'drippcan' — NEVER point this at another app's
# database (lcbo-tracker / anu-imports each have their own).
# Local dev: leave unset to fall back to SQLite (drippcan.db in DB_DIR).
DATABASE_URL=
# Optional: directory for the SQLite dev file (defaults to the repo root)
DB_DIR=

# === LCBO SALE-OF-DATA (sod.lcbo.com) ===
SOD_USER=
SOD_PASSWORD=
SOD_AGENT_ID=1113

# === AUTH TOKENS (generate fresh — do not reuse another app's) ===
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_TOKEN=
# Bearer token the GitHub Action uses for /api/sod/cron and /api/live/refresh
SOD_CRON_TOKEN=
# Gates the owner (brand) view — strong random string, set at deploy
OWNER_PASSCODE=
# Optional: gates ALL /api/* reads behind X-API-Key (unset = open dev mode)
API_KEY=

# === EMAIL (Resend — free tier, 3,000 emails/mo) ===
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
TASTING_DIGEST_TO=

# === CORS ===
# Comma-separated. Defaults already cover the Dripp frontend + local dev:
# https://drippcan-web.vercel.app,http://localhost:3002
CORS_ORIGINS=

# === OPTIONAL ===
ANTHROPIC_API_KEY=
SENTRY_DSN=

# === RUNTIME ===
PORT=5070
FLASK_DEBUG=false
TZ=America/Toronto
